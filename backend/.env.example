OPENAI_API_KEY=sk-...
# Optional: SQLite file for LangGraph checkpoints + API session metadata (default: backend/data/app.sqlite)
# APP_SQLITE_PATH=/path/to/app.sqlite
# Tests set USE_MEMORY_CHECKPOINTER=1 — production uses AsyncSqliteSaver + FastAPI lifespan (do not set in .env).
# Optional: comma-separated browser origins (default: http://localhost:5173)
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
